# Unified Trading System - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ================================
# IBKR Connection Settings
# ================================
IBKR_HOST=127.0.0.1
IBKR_PORT=4002                    # 4002 for paper trading, 7496 for live TWS, 4001 for live Gateway
IBKR_CLIENT_ID=1                  # Unique client ID (1-32)
IBKR_READONLY=false               # Set to true for monitoring only
IBKR_ACCOUNT=                     # Your IBKR account ID (leave empty for default)

# ================================
# Trading Mode
# ================================
TRADING_MODE=paper                # paper | live (ALWAYS start with paper!)
ENABLE_AUTO_TRADING=false         # Manual approval required when false

# ================================
# Data Sources
# ================================
# Yahoo Finance (free, no key needed)
USE_YAHOO_FINANCE=true

# Finviz Elite (optional)
FINVIZ_EMAIL=
FINVIZ_PASSWORD=
FINVIZ_COOKIE=                    # Alternative to email/password
FINVIZ_ELITE=false                # Set to true if you have Elite subscription

# ================================
# AI Features (Optional)
# ================================
OPENAI_API_KEY=                   # For trade narratives
OPENAI_MODEL=gpt-4-turbo-preview  # or gpt-3.5-turbo for lower cost

# ================================
# Email Notifications (Optional)
# ================================
ENABLE_EMAIL_ALERTS=false
SENDGRID_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Gmail Alternative (use app password, not regular password)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ================================
# Risk Limits (can override in config)
# ================================
MAX_POSITION_SIZE_PCT=2.0         # % of account per position
MAX_TOTAL_RISK_PCT=10.0           # % of account at risk across all positions
MAX_POSITIONS=10                  # Maximum concurrent positions
MAX_DAILY_LOSS_PCT=3.0            # Circuit breaker

# ================================
# Logging
# ================================
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# ================================
# Streamlit Dashboard
# ================================
STREAMLIT_PORT=8080
STREAMLIT_AUTO_REFRESH_SEC=5      # Seconds between auto-refresh

# ================================
# File Paths (relative to project root)
# ================================
CONFIG_DIR=config
DATA_DIR=data
LOG_DIR=logs
CACHE_DIR=data/cache

# ================================
# Development
# ================================
DEBUG=false
PYTHONPATH=.
